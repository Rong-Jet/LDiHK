# Web bind port for local/container runs. Many hosts inject this automatically.
PORT=8000

# Hosted Postgres database used by the API, workers, and migrations.
DATABASE_URL=postgresql://user:password@host:5432/database

# Existing S3 bucket where clients upload YouTube Takeout ZIP files under
# uploads/<user_id>/<filename>.zip.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_REGION=
S3_BUCKET=

# YouTube Data API key used by duration enrichment workers/scripts.
YOUTUBE_API_KEY=

# Optional Postgres database used by schema integration tests.
TEST_DATABASE_URL=

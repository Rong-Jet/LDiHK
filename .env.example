# Web bind port for local/container runs. Render injects PORT automatically for
# web services.
PORT=8000

# Hosted Postgres database used by the API, workers, and migrations.
# For Supabase on Render, prefer the Supabase Session Pooler connection string
# if the direct database hostname is not reachable from Render.
DATABASE_URL=postgresql://user:password@host:5432/database

# Optional local/live Postgres database used by schema integration tests.
TEST_DATABASE_URL=

# Comma-separated browser origins allowed to call the backend API.
# Example: https://your-frontend.example.com,http://localhost:5173
FRONTEND_ALLOWED_ORIGINS=

# Demo identity mode. User-scoped frontend requests send:
# Authorization: Bearer <LDiHKID>
# The backend maps that public ldihk_id to the internal Postgres user_id.
REQUIRE_LDIHK_BEARER=true

# Enabled for the v5 demo so top-channel/top-video dashboard views can query
# channel_id and video_id dimensions.
ALLOW_IDENTIFIER_DIMENSIONS=true

# v5 date/hour query buckets use UTC.
QUERY_BUCKET_TIMEZONE=UTC

# Existing S3 bucket where clients upload YouTube Takeout ZIP files under
# uploads/<LDiHKID>/<filename>.zip.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional. Leave empty for long-lived IAM access keys; set only for temporary
# AWS STS credentials.
AWS_SESSION_TOKEN=
AWS_REGION=
S3_BUCKET=

# Maximum S3 ZIP object size accepted by the import worker.
# 1073741824 = 1 GiB.
MAX_IMPORT_ZIP_BYTES=1073741824

# Import worker polling interval when no queued import is available.
IMPORT_WORKER_POLL_INTERVAL_SECONDS=5

# YouTube Data API key used by duration enrichment workers.
YOUTUBE_API_KEY=

# Duration enrichment worker controls.
YOUTUBE_MAX_DURATION_SECONDS=5400
ENRICHMENT_BATCH_SIZE=50
ENRICHMENT_POLL_INTERVAL_SECONDS=30
ENRICHMENT_RETRY_BASE_SECONDS=300

# Runtime logging.
LOG_LEVEL=INFO

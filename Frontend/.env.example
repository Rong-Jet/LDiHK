# Backend API base used by browser calls to /api/query and /api/imports.
# Leave empty to use the local Astro mock API routes.
# Example: http://127.0.0.1:8000
PUBLIC_API_URL=

# Alias also supported by src/lib/api.ts if you prefer a more explicit name.
PUBLIC_BACKEND_API_URL=

# Server-side credentials used only by Astro API routes that generate S3 upload
# URLs. These should match the backend S3_BUCKET so POST /api/imports accepts
# the uploaded object metadata.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional. Set only for temporary AWS STS credentials.
AWS_SESSION_TOKEN=
AWS_REGION=
S3_BUCKET=

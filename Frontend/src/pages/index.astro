---
import Layout from '../layouts/Layout.astro';
---

<Layout title="LDiHK | Social Media Data Analytics Platform">
  <!-- Hero Section -->
  <section class="relative overflow-hidden bg-white py-20 lg:py-32">
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#F4F0E4_1px,transparent_1px),linear-gradient(to_bottom,#F4F0E4_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_100%)] opacity-60"></div>
    
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full bg-brand-beige border border-brand-navy/10 text-xs font-semibold text-brand-navy mb-6 tracking-wide uppercase">
        <span class="w-2 h-2 rounded-full bg-brand-teal animate-pulse"></span>
        Enterprise MVP Live Console
      </div>
      
      <h1 class="text-4xl sm:text-6xl font-extrabold text-brand-navy tracking-tight max-w-4xl mx-auto leading-[1.1] mb-6">
        Decode Your Social Engagement at <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-teal to-brand-navy">Scale</span>
      </h1>
      
      <p class="text-lg sm:text-xl text-brand-navy/70 max-w-2xl mx-auto leading-relaxed mb-10">
        Deploy direct-to-S3 programmatic ingestion, polling pipeline aggregation, and high-performance cross-platform visual matrices in seconds.
      </p>
      
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a 
          href="/dashboard" 
          class="w-full sm:w-auto px-8 py-4 rounded-xl bg-brand-teal text-white font-bold text-base hover:bg-brand-teal/95 transition-all shadow-lg shadow-brand-teal/20 hover:shadow-xl hover:-translate-y-0.5 active:translate-y-0 duration-150"
          id="hero-cta-dashboard"
        >
          Launch Analytics Console
        </a>
        <a 
          href="#pitchdeck" 
          class="w-full sm:w-auto px-8 py-4 rounded-xl bg-brand-beige text-brand-navy font-bold text-base hover:bg-brand-navy/10 transition-all border border-brand-navy/20 duration-150"
          id="hero-cta-pitchdeck"
        >
          Download Pitchdeck
        </a>
      </div>
    </div>
  </section>

  <!-- Core Features Grid -->
  <section class="py-20 bg-brand-beige/50 border-t border-b border-brand-navy/5">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-extrabold text-brand-navy tracking-tight mb-4">
          High-Performance Analytics Architecture
        </h2>
        <p class="text-brand-navy/70 max-w-2xl mx-auto text-base">
          Engineered to bypass local server bottlenecks and render multi-million record analytics instantly.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Feature 1 -->
        <div class="bg-white p-8 rounded-2xl border border-brand-navy/10 shadow-sm hover:shadow-md transition-shadow group">
          <div class="w-12 h-12 rounded-xl bg-brand-beige flex items-center justify-center text-brand-teal font-bold mb-6 group-hover:bg-brand-teal group-hover:text-white transition-colors duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-brand-navy mb-3">Direct-to-S3 Ingestion</h3>
          <p class="text-brand-navy/70 text-sm leading-relaxed">
            Programmatically streams large zip datasets directly to secure S3 buckets via pre-signed PUT tokens, bypassing application server overhead.
          </p>
        </div>

        <!-- Feature 2 -->
        <div class="bg-white p-8 rounded-2xl border border-brand-navy/10 shadow-sm hover:shadow-md transition-shadow group">
          <div class="w-12 h-12 rounded-xl bg-brand-beige flex items-center justify-center text-brand-navy font-bold mb-6 group-hover:bg-brand-teal group-hover:text-white transition-colors duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 002 2h2a2 2 0 002-2z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-brand-navy mb-3">Multi-Dimensional Sync</h3>
          <p class="text-brand-navy/70 text-sm leading-relaxed">
            Utilizes custom React hooks and TanStack Query to poll processing microservices, flattening complex nested JSON schemas on the fly.
          </p>
        </div>

        <!-- Feature 3 -->
        <div class="bg-white p-8 rounded-2xl border border-brand-navy/10 shadow-sm hover:shadow-md transition-shadow group">
          <div class="w-12 h-12 rounded-xl bg-brand-beige flex items-center justify-center text-brand-peach font-bold mb-6 group-hover:bg-brand-teal group-hover:text-white transition-colors duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-brand-navy mb-3">Behavioral Heatmaps</h3>
          <p class="text-brand-navy/70 text-sm leading-relaxed">
            Aggregates raw data into interactive hourly matrix grids, allowing teams to isolate viral user habits by specific social platform filters.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Pitchdeck Section & Download Component -->
  <section id="pitchdeck" class="py-24 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-brand-beige p-8 sm:p-12 rounded-3xl border border-brand-navy/15 flex flex-col md:flex-row items-center gap-8 shadow-sm">
        <div class="flex-grow space-y-4">
          <span class="inline-block px-3 py-1 rounded-md bg-brand-peach/20 text-brand-navy font-bold text-xs uppercase tracking-wider">
            Investor Relations
          </span>
          <h2 class="text-2xl sm:text-3xl font-black text-brand-navy tracking-tight">
            Review the Platform Architecture
          </h2>
          <p class="text-brand-navy/70 text-sm sm:text-base leading-relaxed max-w-lg">
            Download our technical pitchdeck to review the deployment roadmap, Netlify Astro static builds, AWS S3 infrastructure costing, and performance benchmarks.
          </p>
        </div>
        
        <!-- Interactive Pitchdeck Download Component -->
        <div class="w-full md:w-auto shrink-0">
          <div class="bg-white p-6 rounded-2xl border border-brand-navy/10 shadow-sm text-center flex flex-col items-center max-w-xs mx-auto md:max-w-none">
            <div class="w-16 h-16 rounded-xl bg-brand-peach/10 text-brand-peach flex items-center justify-center font-black text-2xl mb-4">
              PDF
            </div>
            <span class="font-bold text-brand-navy text-sm block mb-1">LDiHK_Pitchdeck.pdf</span>
            <span class="text-xs text-brand-navy/50 block mb-6">File Size: 1.5 KB &bull; v1.0.0</span>
            
            <a 
              href="/LDiHK_Pitchdeck.pdf" 
              download="LDiHK_Pitchdeck_v1.pdf"
              class="w-full px-6 py-3.5 rounded-xl bg-brand-teal text-white font-bold text-sm hover:bg-brand-teal/95 transition-all shadow-md shadow-brand-teal/10 hover:shadow-lg hover:-translate-y-0.5 active:translate-y-0 flex items-center justify-center gap-2 duration-150"
              id="pitchdeck-download-button"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
              </svg>
              Download PDF
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- General Info & Support Footer-Card -->
  <section class="py-20 bg-brand-beige border-t border-brand-navy/10 relative overflow-hidden">
    <div class="absolute right-0 bottom-0 w-64 h-64 bg-brand-peach/10 rounded-full blur-3xl pointer-events-none"></div>
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative z-10 space-y-6">
      <h2 class="text-2xl sm:text-3xl font-extrabold text-brand-navy tracking-tight">
        Need Technical Support or Enterprise Licensing?
      </h2>
      <p class="text-brand-navy/70 max-w-xl mx-auto text-sm sm:text-base leading-relaxed">
        Our support agents and solutions architects are available 24/7. Connect directly via our secure production domain.
      </p>
      
      <div class="inline-flex flex-col sm:flex-row items-center gap-4 justify-center">
        <a 
          href="mailto:contact@LDiHK.xyz" 
          class="inline-flex items-center gap-3 px-6 py-3.5 rounded-xl bg-brand-navy text-white font-bold text-sm hover:bg-brand-navy/95 transition-all shadow-md shadow-brand-navy/10 hover:shadow-lg hover:-translate-y-0.5 duration-150"
          id="main-contact-email"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-brand-peach" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          contact@LDiHK.xyz
        </a>
      </div>
    </div>
  </section>
</Layout>
